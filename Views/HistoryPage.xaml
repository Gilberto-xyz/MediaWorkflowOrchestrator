<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="MediaWorkflowOrchestrator.Views.HistoryPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="using:MediaWorkflowOrchestrator.Models"
    mc:Ignorable="d">
    <Grid Padding="24">
        <ScrollViewer
            HorizontalScrollMode="Disabled"
            HorizontalScrollBarVisibility="Disabled"
            VerticalScrollBarVisibility="Visible"
            VerticalScrollMode="Auto">
            <StackPanel Spacing="16">
                <Border Style="{StaticResource CardContainerStyle}">
                    <StackPanel Spacing="12">
                <TextBlock Style="{StaticResource SectionTitleTextStyle}" Text="Workflows guardados" />
                <Button Command="{x:Bind ViewModel.RefreshCommand}" Content="Actualizar" Style="{StaticResource PrimaryCommandButtonStyle}" />
                <ListView
                    ItemsSource="{x:Bind ViewModel.WorkflowHistory, Mode=OneWay}"
                    ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                    ScrollViewer.HorizontalScrollMode="Disabled"
                    ScrollViewer.VerticalScrollBarVisibility="Disabled"
                    ScrollViewer.VerticalScrollMode="Disabled"
                    SelectedItem="{x:Bind ViewModel.SelectedWorkflow, Mode=TwoWay}">
                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="models:WorkflowInstance">
                            <Border Margin="0,0,0,10" Padding="12" Background="{ThemeResource LayerFillColorDefaultBrush}" CornerRadius="12">
                                <StackPanel Spacing="4">
                                    <TextBlock FontWeight="SemiBold" Text="{x:Bind DisplayName}" />
                                    <TextBlock Style="{StaticResource MutedCaptionTextStyle}" Text="{x:Bind RootPath}" />
                                    <TextBlock Style="{StaticResource MutedCaptionTextStyle}" Text="{x:Bind LastExecutionSummary}" />
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource CardContainerStyle}">
                    <StackPanel Spacing="12">
                <TextBlock Style="{StaticResource SectionTitleTextStyle}" Text="Detalle" />
                <TextBlock FontWeight="SemiBold" Text="{x:Bind ViewModel.SelectedDisplayName, Mode=OneWay}" TextWrapping="Wrap" />
                <TextBlock Style="{StaticResource MutedCaptionTextStyle}" Text="{x:Bind ViewModel.SelectedRootPath, Mode=OneWay}" />
                <TextBlock Text="{x:Bind ViewModel.SelectedSummary, Mode=OneWay}" TextWrapping="Wrap" />
                <Button Command="{x:Bind ViewModel.ContinueWorkflowCommand}" Content="Continuar workflow" Style="{StaticResource PrimaryCommandButtonStyle}" />
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
