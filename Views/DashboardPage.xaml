<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="MediaWorkflowOrchestrator.Views.DashboardPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="using:MediaWorkflowOrchestrator.Models"
    mc:Ignorable="d">
    <Grid Padding="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <ScrollViewer
            Grid.Row="1"
            HorizontalScrollMode="Disabled"
            HorizontalScrollBarVisibility="Disabled"
            VerticalScrollBarVisibility="Visible"
            VerticalScrollMode="Auto">
            <StackPanel Spacing="16">
                <Border Style="{StaticResource CardContainerStyle}">
                    <StackPanel Spacing="12">
                        <TextBlock Style="{StaticResource SectionTitleTextStyle}" Text="Workflow actual" />
                        <TextBlock FontSize="20" FontWeight="SemiBold" Text="{x:Bind ViewModel.DisplayName, Mode=OneWay}" TextWrapping="Wrap" />
                        <TextBlock Style="{StaticResource MutedCaptionTextStyle}" Text="{x:Bind ViewModel.RootPath, Mode=OneWay}" />
                        <Grid ColumnSpacing="16" RowSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Spacing="4">
                                <TextBlock Style="{StaticResource MutedCaptionTextStyle}" Text="Siguiente paso" />
                                <TextBlock FontWeight="SemiBold" Text="{x:Bind ViewModel.NextStepLabel, Mode=OneWay}" TextWrapping="Wrap" />
                            </StackPanel>
                            <StackPanel Grid.Column="1" Spacing="4">
                                <TextBlock Style="{StaticResource MutedCaptionTextStyle}" Text="Estado global" />
                                <TextBlock FontWeight="SemiBold" Text="{x:Bind ViewModel.GlobalStatus, Mode=OneWay}" TextWrapping="Wrap" />
                            </StackPanel>
                        </Grid>
                        <InfoBar
                            IsClosable="False"
                            IsOpen="{x:Bind ViewModel.IsStatusInfoOpen, Mode=OneWay}"
                            Message="{x:Bind ViewModel.StatusMessage, Mode=OneWay}"
                            Severity="{x:Bind ViewModel.StatusSeverity, Mode=OneWay}" />
                        <StackPanel x:Name="TranslationDecisionPanel" Spacing="12">
                            <Button Command="{x:Bind ViewModel.MarkTranslateRequiredCommand}" Content="Traducir subs" Style="{StaticResource PrimaryCommandButtonStyle}" />
                            <Button Command="{x:Bind ViewModel.MarkTranslateSkippedCommand}" Content="Omitir traducción" />
                        </StackPanel>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource CardContainerStyle}">
                    <StackPanel Spacing="12">
                        <TextBlock Style="{StaticResource SectionTitleTextStyle}" Text="{x:Bind ViewModel.QuickOptionsTitle, Mode=OneWay}" />
                        <TextBlock Style="{StaticResource MutedCaptionTextStyle}" Text="{x:Bind ViewModel.QuickOptionsDescription, Mode=OneWay}" TextWrapping="Wrap" />

                        <StackPanel x:Name="SkipAheadPanel" Orientation="Horizontal" Spacing="12">
                            <Button Command="{x:Bind ViewModel.PrepareSelectedStepCommand}" Content="Saltar previos hasta este paso" />
                            <Button Command="{x:Bind ViewModel.PrepareAndRunSelectedStepCommand}" Content="Saltar previos y ejecutar ahora" Style="{StaticResource PrimaryCommandButtonStyle}" />
                        </StackPanel>

                        <StackPanel x:Name="DownloadQuickOptionsPanel" Orientation="Horizontal" Spacing="12">
                            <ToggleButton Command="{x:Bind ViewModel.ToggleDownloadDryRunCommand}" Content="{x:Bind ViewModel.DownloadDryRunButtonLabel, Mode=OneWay}" IsChecked="{x:Bind ViewModel.DownloadDryRunEnabled, Mode=OneWay}" Style="{StaticResource QuickToggleButtonStyle}" />
                            <ToggleButton Command="{x:Bind ViewModel.ToggleDownloadForceLatestCommand}" Content="{x:Bind ViewModel.DownloadForceLatestButtonLabel, Mode=OneWay}" IsChecked="{x:Bind ViewModel.DownloadForceLatestEnabled, Mode=OneWay}" Style="{StaticResource QuickToggleButtonStyle}" />
                        </StackPanel>

                        <StackPanel x:Name="TranslateQuickOptionsPanel" Orientation="Horizontal" Spacing="12">
                            <ToggleButton Command="{x:Bind ViewModel.ToggleTranslateFastModeCommand}" Content="{x:Bind ViewModel.TranslateFastModeButtonLabel, Mode=OneWay}" IsChecked="{x:Bind ViewModel.TranslateFastModeEnabled, Mode=OneWay}" Style="{StaticResource QuickToggleButtonStyle}" />
                            <ToggleButton Command="{x:Bind ViewModel.ToggleTranslateSkipSummaryCommand}" Content="{x:Bind ViewModel.TranslateSkipSummaryButtonLabel, Mode=OneWay}" IsChecked="{x:Bind ViewModel.TranslateSkipSummaryEnabled, Mode=OneWay}" Style="{StaticResource QuickToggleButtonStyle}" />
                        </StackPanel>

                        <StackPanel x:Name="CleanTracksQuickOptionsPanel" Orientation="Horizontal" Spacing="12">
                            <ToggleButton Command="{x:Bind ViewModel.ToggleCleanupCloseQbittorrentCommand}" Content="{x:Bind ViewModel.CleanupCloseQbittorrentButtonLabel, Mode=OneWay}" IsChecked="{x:Bind ViewModel.CleanupCloseQbittorrentEnabled, Mode=OneWay}" Style="{StaticResource QuickToggleButtonStyle}" />
                            <ToggleButton Command="{x:Bind ViewModel.ToggleCleanupDeleteOriginalsCommand}" Content="{x:Bind ViewModel.CleanupDeleteOriginalsButtonLabel, Mode=OneWay}" IsChecked="{x:Bind ViewModel.CleanupDeleteOriginalsEnabled, Mode=OneWay}" Style="{StaticResource QuickToggleButtonStyle}" />
                        </StackPanel>

                        <StackPanel x:Name="PackageRarQuickOptionsPanel" Orientation="Horizontal" Spacing="12">
                            <ToggleButton Command="{x:Bind ViewModel.ToggleRarSkipImagesCommand}" Content="{x:Bind ViewModel.RarSkipImagesButtonLabel, Mode=OneWay}" IsChecked="{x:Bind ViewModel.RarSkipImagesEnabled, Mode=OneWay}" Style="{StaticResource QuickToggleButtonStyle}" />
                            <ToggleButton Command="{x:Bind ViewModel.ToggleRarNoCompressCommand}" Content="{x:Bind ViewModel.RarNoCompressButtonLabel, Mode=OneWay}" IsChecked="{x:Bind ViewModel.RarNoCompressEnabled, Mode=OneWay}" Style="{StaticResource QuickToggleButtonStyle}" />
                            <ToggleButton Command="{x:Bind ViewModel.ToggleRarCompressionModeCommand}" Content="{x:Bind ViewModel.RarCompressionModeButtonLabel, Mode=OneWay}" IsChecked="{x:Bind ViewModel.RarUseCompressionNormalEnabled, Mode=OneWay}" Style="{StaticResource QuickToggleButtonStyle}" />
                            <Button Command="{x:Bind ViewModel.CycleRarImageFormatCommand}" Content="{x:Bind ViewModel.RarImageFormatButtonLabel, Mode=OneWay}" />
                            <ToggleButton Command="{x:Bind ViewModel.ToggleRarVerboseCommand}" Content="{x:Bind ViewModel.RarVerboseButtonLabel, Mode=OneWay}" IsChecked="{x:Bind ViewModel.RarVerboseEnabled, Mode=OneWay}" Style="{StaticResource QuickToggleButtonStyle}" />
                        </StackPanel>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource CardContainerStyle}">
                    <StackPanel Spacing="12">
                        <TextBlock Style="{StaticResource SectionTitleTextStyle}" Text="Pasos" />
                        <ItemsControl ItemsSource="{x:Bind ViewModel.StepItems, Mode=OneWay}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="models:WorkflowStepState">
                                    <Button
                                        Background="Transparent"
                                        BorderThickness="0"
                                        Click="OnStepItemClicked"
                                        HorizontalAlignment="Stretch"
                                        HorizontalContentAlignment="Stretch"
                                        Padding="0">
                                        <Border
                                            Margin="0,0,0,10"
                                            Padding="12"
                                            Background="{x:Bind CardBackgroundBrush, Mode=OneWay}"
                                            BorderBrush="{x:Bind CardBorderBrush, Mode=OneWay}"
                                            BorderThickness="{x:Bind CardBorderThickness, Mode=OneWay}"
                                            CornerRadius="12">
                                            <Grid ColumnSpacing="12" RowSpacing="8">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <StackPanel Grid.Column="0" Spacing="4">
                                                    <TextBlock
                                                        FontWeight="SemiBold"
                                                        Foreground="{x:Bind TitleBrush, Mode=OneWay}"
                                                        Text="{x:Bind DisplayName, Mode=OneWay}"
                                                        TextWrapping="Wrap" />
                                                    <TextBlock
                                                        Style="{StaticResource MutedCaptionTextStyle}"
                                                        Foreground="{x:Bind ReasonBrush, Mode=OneWay}"
                                                        Text="{x:Bind StatusReason, Mode=OneWay}" />
                                                </StackPanel>
                                                <StackPanel Grid.Column="1" HorizontalAlignment="Right" Spacing="4">
                                                    <TextBlock
                                                        HorizontalAlignment="Right"
                                                        FontSize="11"
                                                        FontWeight="SemiBold"
                                                        Foreground="{StaticResource AccentPrimaryBrush}"
                                                        Text="{x:Bind SelectionLabel, Mode=OneWay}" />
                                                    <TextBlock
                                                        HorizontalAlignment="Right"
                                                        FontWeight="SemiBold"
                                                        Foreground="{x:Bind StatusAccentBrush, Mode=OneWay}"
                                                        Text="{x:Bind Status, Mode=OneWay}"
                                                        TextWrapping="WrapWholeWords" />
                                                    <TextBlock HorizontalAlignment="Right" Style="{StaticResource MutedCaptionTextStyle}" Text="{x:Bind FinishedAtDisplay, Mode=OneWay}" />
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource CardContainerStyle}">
                    <Grid RowSpacing="12">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <StackPanel Grid.Row="0" Spacing="8">
                            <TextBlock Style="{StaticResource SectionTitleTextStyle}" Text="Detalle y salida" />
                            <TextBlock FontWeight="SemiBold" Text="{x:Bind ViewModel.SelectedStepTitle, Mode=OneWay}" TextWrapping="Wrap" />
                            <TextBlock Style="{StaticResource MutedCaptionTextStyle}" Text="{x:Bind ViewModel.SelectedStepDescription, Mode=OneWay}" />
                            <StackPanel x:Name="PackageRarDetailActionsPanel" Spacing="8">
                                <TextBlock Style="{StaticResource MutedCaptionTextStyle}" Text="{x:Bind ViewModel.PackageRarDetailSummary, Mode=OneWay}" />
                                <StackPanel Orientation="Horizontal" Spacing="12">
                                    <Button
                                        Background="{x:Bind ViewModel.PackageRarRawDataButtonBackground, Mode=OneWay}"
                                        BorderBrush="{x:Bind ViewModel.PackageRarRawDataButtonBorderBrush, Mode=OneWay}"
                                        Command="{x:Bind ViewModel.CopyPackageRarRawDataCommand}"
                                        Content="{x:Bind ViewModel.PackageRarRawDataButtonLabel, Mode=OneWay}"
                                        Foreground="{x:Bind ViewModel.PackageRarRawDataButtonForeground, Mode=OneWay}" />
                                    <Button
                                        Background="{x:Bind ViewModel.PackageRarWeightSummaryButtonBackground, Mode=OneWay}"
                                        BorderBrush="{x:Bind ViewModel.PackageRarWeightSummaryButtonBorderBrush, Mode=OneWay}"
                                        Command="{x:Bind ViewModel.CopyPackageRarWeightSummaryCommand}"
                                        Content="{x:Bind ViewModel.PackageRarWeightSummaryButtonLabel, Mode=OneWay}"
                                        Foreground="{x:Bind ViewModel.PackageRarWeightSummaryButtonForeground, Mode=OneWay}" />
                                    <Button
                                        Background="{x:Bind ViewModel.PackageRarCleanNameButtonBackground, Mode=OneWay}"
                                        BorderBrush="{x:Bind ViewModel.PackageRarCleanNameButtonBorderBrush, Mode=OneWay}"
                                        Command="{x:Bind ViewModel.CopyPackageRarCleanNameCommand}"
                                        Content="{x:Bind ViewModel.PackageRarCleanNameButtonLabel, Mode=OneWay}"
                                        Foreground="{x:Bind ViewModel.PackageRarCleanNameButtonForeground, Mode=OneWay}" />
                                </StackPanel>
                            </StackPanel>
                        </StackPanel>
                        <TextBox
                            Grid.Row="1"
                            AcceptsReturn="True"
                            FontFamily="Consolas"
                            HorizontalAlignment="Stretch"
                            IsReadOnly="True"
                            MinHeight="260"
                            MaxHeight="520"
                            ScrollViewer.HorizontalScrollBarVisibility="Auto"
                            ScrollViewer.VerticalScrollBarVisibility="Visible"
                            Text="{x:Bind ViewModel.DetailOutput, Mode=OneWay}"
                            TextWrapping="Wrap" />
                    </Grid>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
