<?xml version="1.0" encoding="utf-8" ?>
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Color x:Key="AccentPrimaryColor">#D97706</Color>
    <Color x:Key="AccentSecondaryColor">#0F766E</Color>
    <Color x:Key="SurfaceMutedColor">#13202C</Color>
    <Color x:Key="BackdropNightColor">#050814</Color>
    <Color x:Key="BackdropDeepTealColor">#0A1B26</Color>
    <Color x:Key="BackdropCinemaColor">#1A0F12</Color>
    <Color x:Key="MatrixGlowColor">#2AF598</Color>
    <Color x:Key="AnimeSkyColor">#5ED3FF</Color>
    <Color x:Key="CinemaGlowColor">#FF9F43</Color>
    <Color x:Key="SuccessColor">#2E8B57</Color>
    <Color x:Key="WarningColor">#C97A00</Color>
    <Color x:Key="DangerColor">#B42318</Color>

    <SolidColorBrush x:Key="AccentPrimaryBrush" Color="{StaticResource AccentPrimaryColor}" />
    <SolidColorBrush x:Key="AccentSecondaryBrush" Color="{StaticResource AccentSecondaryColor}" />
    <SolidColorBrush x:Key="SurfaceMutedBrush" Color="{StaticResource SurfaceMutedColor}" />
    <SolidColorBrush x:Key="CardGlassBrush" Color="#AA131A24" />
    <SolidColorBrush x:Key="PaneGlassBrush" Color="#B2141822" />
    <SolidColorBrush x:Key="OverlayStrokeBrush" Color="#44F8FAFF" />
    <SolidColorBrush x:Key="SuccessBrush" Color="{StaticResource SuccessColor}" />
    <SolidColorBrush x:Key="WarningBrush" Color="{StaticResource WarningColor}" />
    <SolidColorBrush x:Key="DangerBrush" Color="{StaticResource DangerColor}" />

    <LinearGradientBrush x:Key="WindowBackdropBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="{StaticResource BackdropNightColor}" Offset="0" />
        <GradientStop Color="{StaticResource BackdropDeepTealColor}" Offset="0.45" />
        <GradientStop Color="{StaticResource BackdropCinemaColor}" Offset="1" />
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="CinematicVeilBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#2208F7D0" Offset="0" />
        <GradientStop Color="#00000000" Offset="0.4" />
        <GradientStop Color="#1FAA6B11" Offset="1" />
    </LinearGradientBrush>

    <RadialGradientBrush x:Key="MatrixGlowBrush" RadiusX="0.7" RadiusY="0.7">
        <GradientStop Color="#A02AF598" Offset="0" />
        <GradientStop Color="#402AF598" Offset="0.55" />
        <GradientStop Color="#00000000" Offset="1" />
    </RadialGradientBrush>

    <RadialGradientBrush x:Key="AnimeGlowBrush" RadiusX="0.7" RadiusY="0.7">
        <GradientStop Color="#905ED3FF" Offset="0" />
        <GradientStop Color="#305ED3FF" Offset="0.6" />
        <GradientStop Color="#00000000" Offset="1" />
    </RadialGradientBrush>

    <RadialGradientBrush x:Key="CinemaGlowBrush" RadiusX="0.75" RadiusY="0.75">
        <GradientStop Color="#90FF9F43" Offset="0" />
        <GradientStop Color="#25FF9F43" Offset="0.55" />
        <GradientStop Color="#00000000" Offset="1" />
    </RadialGradientBrush>

    <LinearGradientBrush x:Key="SweepAccentBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#0037E3A5" Offset="0" />
        <GradientStop Color="#66D97706" Offset="0.48" />
        <GradientStop Color="#002BE9FF" Offset="1" />
    </LinearGradientBrush>

    <Style x:Key="HeroTitleTextStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="30" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="TextWrapping" Value="Wrap" />
    </Style>

    <Style x:Key="SectionTitleTextStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="18" />
        <Setter Property="FontWeight" Value="SemiBold" />
    </Style>

    <Style x:Key="MutedCaptionTextStyle" TargetType="TextBlock">
        <Setter Property="Opacity" Value="0.72" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="TextWrapping" Value="Wrap" />
    </Style>

    <Style x:Key="CardContainerStyle" TargetType="Border">
        <Setter Property="CornerRadius" Value="16" />
        <Setter Property="Padding" Value="20" />
        <Setter Property="Margin" Value="0,0,0,16" />
        <Setter Property="Background" Value="{StaticResource CardGlassBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource OverlayStrokeBrush}" />
        <Setter Property="BorderThickness" Value="1" />
    </Style>

    <Style x:Key="PrimaryCommandButtonStyle" TargetType="Button">
        <Setter Property="Padding" Value="14,10" />
        <Setter Property="CornerRadius" Value="10" />
        <Setter Property="Background" Value="{StaticResource AccentPrimaryBrush}" />
        <Setter Property="Foreground" Value="White" />
    </Style>

    <Style x:Key="QuickToggleButtonStyle" TargetType="ToggleButton">
        <Setter Property="Padding" Value="14,10" />
        <Setter Property="CornerRadius" Value="10" />
        <Setter Property="BorderThickness" Value="1" />
    </Style>
</ResourceDictionary>
